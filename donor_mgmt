import tkinter as tk
from tkinter import messagebox
import sqlite3

def open_donor_mgmt():
    win = tk.Toplevel()
    win.title("Donor Management")
    win.geometry("350x350")
    
    tk.Label(win, text="Donor Name:").pack(pady=5)
    name_entry = tk.Entry(win)
    name_entry.pack(pady=5)
    
    tk.Label(win, text="Blood Type (e.g. A+):").pack(pady=5)
    type_entry = tk.Entry(win)
    type_entry.pack(pady=5)

    def register_donor():
        name = name_entry.get().strip()
        b_type = type_entry.get().strip().upper()
        
        if not name or not b_type:
            messagebox.showwarning("Warning", "Please fill all fields")
            return

        try:
            conn = sqlite3.connect('blood_bank.db')
            cursor = conn.cursor()
            
            # 1. Add Donor to records
            cursor.execute("INSERT INTO donors (name, b_type) VALUES (?, ?)", (name, b_type))
            
            # 2. Update Inventory (+1 bag)
            cursor.execute("UPDATE inventory SET count = count + 1 WHERE blood_type = ?", (b_type,))
            
            if cursor.rowcount > 0:
                conn.commit()
                messagebox.showinfo("Success", f"Donor {name} added. {b_type} stock increased!")
                name_entry.delete(0, tk.END)
                type_entry.delete(0, tk.END)
            else:
                messagebox.showerror("Error", f"Blood type {b_type} not found in inventory!")
                
        except Exception as e:
            messagebox.showerror("Error", f"Database error: {str(e)}")
        finally:
            conn.close()

    tk.Button(win, text="Register Donor", command=register_donor, bg="green", fg="white", width=20).pack(pady=20)
